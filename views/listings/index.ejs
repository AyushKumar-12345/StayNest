<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    align-items: center;
    padding: 1rem 0;
  }

  .filter {
    text-align: center;
    margin-right: 2rem;
    opacity: 0.7;
    transition: 0.2s ease;
    text-decoration: none;
    color: inherit;
    min-width: 60px;
  }

  .filter:hover {
    opacity: 1;
    transform: translateY(-2px);
    color: #ff385c;
  }

  .filter p {
    font-size: 0.75rem;
    margin-top: 0.25rem;
    font-weight: 600;
  }

  .filter i {
    font-size: 1.35rem;
  }

  #filters::-webkit-scrollbar {
    display: none;
  }

  .listing-card {
    border: none !important;
    margin-bottom: 2rem;
    transition: 0.2s ease;
  }

  .listing-card:hover {
    transform: translateY(-4px);
  }

  .listing-img {
    border-radius: 1rem !important;
    width: 100%;
    height: 18rem !important;
    object-fit: cover;
  }

  .card-body {
    padding: 0.5rem 0 !important;
  }

  .listing-link {
    text-decoration: none;
    color: inherit;
  }
</style>

<div class="container my-3">
  <div id="filters">
    <a href="/listings" class="filter">
      <i class="fa-solid fa-border-all"></i>
      <p>All</p>
    </a>

    <a href="/listings?category=Trending" class="filter">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </a>

    <a href="/listings?category=Rooms" class="filter">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </a>

    <a href="/listings?category=Cities" class="filter">
      <i class="fa-solid fa-mountain-city"></i>
      <p>Cities</p>
    </a>

    <a href="/listings?category=Mountains" class="filter">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </a>

    <a href="/listings?category=Castles" class="filter">
      <i class="fa-solid fa-fort-awesome"></i>
      <p>Castles</p>
    </a>

    <a href="/listings?category=Pools" class="filter">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Pools</p>
    </a>

    <a href="/listings?category=Camping" class="filter">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </a>

    <a href="/listings?category=Farms" class="filter">
      <i class="fa-solid fa-cow"></i>
      <p>Farms</p>
    </a>

    <a href="/listings?category=Arctic" class="filter">
      <i class="fa-solid fa-snowflake"></i>
      <p>Arctic</p>
    </a>

    <a href="/listings?category=Domes" class="filter">
      <i class="fa-solid fa-igloo"></i>
      <p>Domes</p>
    </a>

    <a href="/listings?category=Boats" class="filter">
      <i class="fa-solid fa-ship"></i>
      <p>Boats</p>
    </a>
  </div>

  <hr class="mt-0 mb-4">

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4 justify-content-center">
    <% if (allListings?.length) { %>
      <% allListings.forEach(listing => { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card h-100 shadow-sm p-2 rounded-4">
              <img src="<%= listing.image?.url || 'https://placehold.co/900x600?text=StayNest' %>" class="card-img-top listing-img" alt="<%= listing.title %>">
              <div class="card-body">
                <h5 class="fw-bold text-truncate mb-1"><%= listing.title %></h5>
                <p class="text-muted small mb-2">
                  <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <span class="fw-bold text-danger">
                    ₹<%= (listing.price || 0).toLocaleString("en-IN") %>
                    <span class="text-secondary fw-normal small">/ night</span>
                  </span>
                  <span class="badge bg-light text-dark border"><%= listing.category %></span>
                </div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center my-5 py-5">
        <div class="text-danger mb-4">
          <i class="fa-solid fa-cloud-moon fa-4x"></i>
        </div>
        <h3 class="fw-bold">No Properties Listed Here Yet</h3>
        <p class="text-secondary mb-4">We couldn't find matches under this category.</p>
        <a href="/listings" class="btn btn-danger btn-lg rounded-3 fw-bold">
          <i class="fa-solid fa-rotate-left me-2"></i>Clear Filters
        </a>
      </div>
    <% } %>
  </div>
</div>