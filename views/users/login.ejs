<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center my-5">
  <div class="col-lg-5 col-md-7">
    <div class="card border-0 shadow rounded-4">
      <div class="card-body p-5">
        <div class="text-center mb-4">
          <i class="fa-solid fa-right-to-bracket text-danger fs-1 mb-3"></i>
          <h2 class="fw-bold">Welcome Back</h2>
          <p class="text-muted">Login to your StayNest account</p>
        </div>

        <form action="/login" method="POST" class="needs-validation" novalidate>
          <div class="mb-4">
            <label for="username" class="form-label fw-semibold">Username</label>
            <input id="username" name="username" type="text" class="form-control" placeholder="Enter your username" required>
            <div class="invalid-feedback">Please enter your username.</div>
          </div>

          <div class="mb-4">
            <label for="password" class="form-label fw-semibold">Password</label>
            <input id="password" name="password" type="password" class="form-control" placeholder="Enter your password" required>
            <div class="invalid-feedback">Please enter your password.</div>
          </div>

          <div class="d-grid mb-3">
            <button class="btn btn-danger btn-lg rounded-3 fw-bold">
              <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Login
            </button>
          </div>
        </form>

        <div class="text-center">
          <small class="text-muted">
            Don't have an account?
            <a href="/signup" class="text-decoration-none fw-semibold text-danger">Sign Up</a>
          </small>
        </div>
      </div>
    </div>
  </div>
</div>